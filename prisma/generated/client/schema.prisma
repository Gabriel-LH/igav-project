  payrollItems                   PayrollItem[]
  payrollLineItems               PayrollLineItem[]
  payrollPolicies                PayrollPolicy[]
  payrollRuns                    PayrollRun[]
  permissions                    Permission[]
  planFeatures                   PlanFeature[]
  planLimits                     PlanLimit[]
  planModules                    PlanModule[]
  plans                          Plan[]
  priceHistories                 PriceHistory[]
  products                       Product[]
  productVariants                ProductVariant[]
  promotionUsages                PromotionUsage[]
  promotions                     Promotion[]
  referrals                      Referral[]
  referralPrograms               ReferralProgram[]
  referralRewards                ReferralReward[]
  rentals                        Rental[]
  rentalCharges                  RentalCharge[]
  rentalItems                    RentalItem[]
  rentalItemStatusHistories      RentalItemStatusHistory[]
  rentalStatusHistories          RentalStatusHistory[]
  reservations                   Reservation[]
  reservationItems               ReservationItem[]
  reservationItemStatusHistories ReservationItemStatusHistory[]
  reversalItems                  ReversalItem[]
  rolePermissions                RolePermission[]
  roles                          Role[]
  sales                          Sale[]
  saleCharges                    SaleCharge[]
  saleItems                      SaleItem[]
  saleItemStatusHistories        SaleItemStatusHistory[]
  saleReversals                  SaleReversal[]
  shifts                         Shift[]
  stockLots                      StockLot[]
  stockMovements                 StockMovement[]
  discountsApplied               DiscountApplied[]
  owner                          User                           @relation("TenantOwner", fields: [ownerId], references: [id])
  tenantConfigs                  TenantConfig?
  userTenantMemberships          UserTenantMembership[]
  tenantPolicies                 TenantPolicy[]
  tenantSubscriptions            TenantSubscription[]
  transfers                      Transfer[]
  transferRoutes                 TransferRoute[]
  userAttendances                UserAttendance[]
  userBranchAccesses             UserBranchAccess[]
  userRoleBranchHistories        UserRoleBranchHistory[]
  userShiftAssignments           UserShiftAssignment[]

  @@map("tenant")
}

model TenantConfig {
  tenantId  String   @id
  config    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_configs")
}

model TenantSubscription {
  id                     String                   @id @default(uuid())
  tenantId               String
  planId                 String
  status                 TenantSubsCriptionStatus
  billingCycle           BillingCycle             @default(monthly)
  startedAt              DateTime
  trialEndsAt            DateTime?
  currentPeriodStart     DateTime
  currentPeriodEnd       DateTime
  provider               Provider
  externalSubscriptionId String?
  createdAt              DateTime                 @default(now())
  createdBy              String?
  plan                   Plan                     @relation(fields: [planId], references: [id])
  tenant                 Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_subscriptions")
}

model TenantModule {
  id        String             @id @default(uuid())
  tenantId  String
  moduleId  String
  status    TenantModuleStatus
  staterdAt DateTime
  module    Module             @relation(fields: [moduleId], references: [id])
  tenant    Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model TenantPolicy {
  id                    String                @id @default(cuid())
  tenantId              String
  version               Int
  isActive              Boolean               @default(true)
  createdAt             DateTime              @default(now())
  updatedBy             String
  changeReason          String?
  sales                 Json
  rentals               Json
  reservations          Json
  inventory             Json
  financial             Json
  security              Json
  tenant                Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  updatedByUser         User                  @relation(fields: [updatedBy], references: [id])
  tenantPolicyHistories TenantPolicyHistory[]

  @@unique([tenantId, version])
  @@map("tenant_policies")
}

model TenantPolicyHistory {
  id            String       @id @default(uuid())
  policyId      String
  version       Int
  sales         Json
  rentals       Json
  reservations  Json
  inventory     Json
  financial     Json
  security      Json
  changedAt     DateTime     @default(now())
  changedBy     String
  changeReason  String?
  changedByUser User         @relation(fields: [changedBy], references: [id])
  policy        TenantPolicy @relation(fields: [policyId], references: [id])

  @@unique([policyId, version])
  @@map("tenant_policy_history")
}

model Invitation {
  id               String           @id @default(uuid())
  tenantId         String
  branchId         String
  roleId           String
  email            String
  token            String           @unique @default(uuid())
  status           InvitationStatus @default(pending)
  invitedById      String
  expiresAt        DateTime
  acceptedAt       DateTime?
  acceptedByUserId String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  acceptedBy       User?            @relation("InvitationsAccepted", fields: [acceptedByUserId], references: [id])
  branch           Branch           @relation(fields: [branchId], references: [id])
  invitedBy        User             @relation("InvitationsSent", fields: [invitedById], references: [id])
  role             Role             @relation(fields: [roleId], references: [id])
  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([token])
  @@index([email])
  @@map("invitation")
}

model UserTenantMembership {
  id                      String                  @id @default(uuid())
  userId                  String
  tenantId                String
  roleId                  String
  defaultBranchId         String
  status                  TenantMemberShipStatus
  invitedBy               String?
  createdAt               DateTime
  updatedAt               DateTime
  pinHash                 String?
  pinSetAt                DateTime?
  payrollConfigs          PayrollConfig[]
  payrollItems            PayrollItem[]
  branch                  Branch                  @relation(fields: [defaultBranchId], references: [id])
  role                    Role                    @relation(fields: [roleId], references: [id])
  tenant                  Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                    User                    @relation(fields: [userId], references: [id])
  userRoleBranchHistories UserRoleBranchHistory[]
  userShiftAssignments    UserShiftAssignment[]

  @@map("tenant_member_ship")
}

model Transfer {
  id                  String           @id @default(uuid())
  tenantId            String
  referenceNumber     String
  originBranchId      String
  destinationBranchId String
  priority            TransferPriority @default(normal)
  requiresApproval    Boolean          @default(false)
  status              TransferStatus
  sentAt              DateTime
  receivedAt          DateTime
  notes               String?
  metadata            Json?
  createdAt           DateTime
  createdBy           String
  approvedBy          String?
  approvedAt          DateTime?
  transferItems       TransferItem[]
  branchDestination   Branch           @relation("DestinationTransfers", fields: [destinationBranchId], references: [id])
  branchOrigin        Branch           @relation("OriginTransfers", fields: [originBranchId], references: [id])
  tenant              Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("transfer")
}

model TransferItem {
  id               String         @id @default(uuid())
  transferId       String
  productId        String
  variantId        String
  quantitySent     Int
  quantityReceived Int?
  createdAt        DateTime
  product          Product        @relation(fields: [productId], references: [id])
  transfer         Transfer       @relation(fields: [transferId], references: [id])
  variant          ProductVariant @relation(fields: [variantId], references: [id])

  @@map("tranfer_item")
}

model TransferRoute {
  id                  String              @id @default(uuid())
  tenantId            String
  originBranchId      String
  destinationBranchId String
  estimatedTimeHours  Int
  status              TransferRouteStatus
  createdAt           DateTime
  destinationBranch   Branch              @relation("DestinationRoutes", fields: [destinationBranchId], references: [id])
  originBranch        Branch              @relation("OriginRoutes", fields: [originBranchId], references: [id])
  tenant              Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("transfer_route")
}

model InventoryMovement {
  id            String                         @id @default(uuid())
  tenantId      String
  branchId      String
  productId     String
  variantId     String?
  type          InventoryMovementType
  referenceType InventoryMovementReferenceType
  referenceId   String
  quantity      Int
  unitCost      Float
  createdBy     DateTime
  createdAt     DateTime
  branch        Branch                         @relation(fields: [branchId], references: [id])
  product       Product                        @relation(fields: [productId], references: [id])
  tenant        Tenant                         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  variant       ProductVariant?                @relation(fields: [variantId], references: [id])

  @@map("inventory_movement")
}

