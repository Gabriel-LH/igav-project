generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String                 @id
  name                  String
  email                 String                 @unique
  dni                   String?                @unique
  emailVerified         Boolean                @default(false)
  image                 String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  status                StatusUser             @default(active)
  createdBy             String                 @default("system")
  updatedBy             String                 @default("system")
  deletedAt             DateTime?
  deletedBy             String?
  globalRole            GlobalRole             @default(USER)
  accounts              Account[]
  closedCashSessions    CashSession[]          @relation("SessionCloser")
  openedCashSessions    CashSession[]          @relation("SessionOpener")
  receivedGuarantees    Guarantee[]            @relation("GuaranteeReceiver")
  returnedGuarantees    Guarantee[]            @relation("GuaranteeReturner")
  invitationsAccepted   Invitation[]           @relation("InvitationsAccepted")
  invitationsSent       Invitation[]           @relation("InvitationsSent")
  operations            Operation[]
  payments              Payment[]
  priceHistories        PriceHistory[]
  sessions              Session[]
  stockMovements        StockMovement[]
  tenants               Tenant[]               @relation("TenantOwner")
  userTenantMemberships UserTenantMembership[]
  tenantPolicies        TenantPolicy[]
  tenantPolicyHistories TenantPolicyHistory[]
  userAttendances       UserAttendance[]
  userBranchAccesses    UserBranchAccess[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Jwks {
  id         String   @id
  publicKey  String   @unique
  privateKey String
  createdAt  DateTime @default(now())

  @@map("jwks")
}

model UserBranchAccess {
  id        String       @id @default(uuid())
  tenantId  String
  branchId  String
  userId    String
  roleId    String
  isPrimary Boolean      @default(false)
  status    BranchStatus @default(active)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  createdBy String
  updatedBy String
  branch    Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  role      Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)
  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, branchId])
  @@index([tenantId])
  @@index([branchId])
  @@index([userId])
  @@map("user_branch_access")
}

model UserAttendance {
  id            String    @id @default(uuid())
  tenantId      String
  branchId      String
  userId        String
  shiftId       String
  checkIn       DateTime?
  checkOut      DateTime?
  notes         String?
  createdBy     String
  status        String    @default("present")
  source        String
  lateMinutes   Int       @default(0)
  extraMinutes  Int       @default(0)
  workDate      DateTime
  isManual      Boolean   @default(false)
  justification String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  branch        Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  shift         Shift     @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_attendance")
}

model UserRoleBranchHistory {
  id           String               @id @default(uuid())
  tenantId     String
  membershipId String
  roleId       String
  branchId     String
  shiftId      String
  startDate    DateTime
  endDate      DateTime
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  createdBy    String
  updatedBy    String
  branch       Branch               @relation(fields: [branchId], references: [id], onDelete: Cascade)
  membership   UserTenantMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  role         Role                 @relation(fields: [roleId], references: [id], onDelete: Cascade)
  shift        Shift                @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("user_role_branch_history")
}

model UserShiftAssignment {
  id           String               @id @default(uuid())
  tenantId     String
  membershipId String
  shiftId      String
  startDate    DateTime
  endDate      DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  createdBy    String
  updatedBy    String
  membership   UserTenantMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  shift        Shift                @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("user_shift_assignment")
}

model AttributeType {
  id              String             @id @default(uuid())
  tenantId        String
  name            String
  code            String
  inputType       AttributeInputType
  isVariant       Boolean
  affectsSku      Boolean
  isActive        Boolean            @default(true)
  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  attributeValues AttributeValue[]

  @@map("attribute_type")
}

model AttributeValue {
  id              String        @id @default(uuid())
  tenantId        String
  code            String
  value           String
  attributeTypeId String
  hexColor        String
  isActive        Boolean
  attributeType   AttributeType @relation(fields: [attributeTypeId], references: [id], onDelete: Cascade)
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("attribute_value")
}

model Branch {
  id                      String                  @id @default(uuid())
  tenantId                String
  code                    String
  name                    String
  city                    String
  address                 String
  phone                   String?
  email                   String?
  timezone                String                  @default("America/Lima")
  isPrimary               Boolean                 @default(false)
  status                  BranchStatus            @default(active)
  metadata                Json?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  createdBy               String?
  updatedBy               String?
  tenant                  Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchConfigs           BranchConfig[]
  cashSessions            CashSession[]
  guarantees              Guarantee[]
  inventoryItems          InventoryItem[]
  inventoryMovements      InventoryMovement[]
  invitations             Invitation[]
  operations              Operation[]
  payments                Payment[]
  payrollRuns             PayrollRun[]
  promotionBranches       PromotionBranch[]
  rentals                 Rental[]
  reservations            Reservation[]
  sales                   Sale[]
  stockLots               StockLot[]
  userTenantMemberships   UserTenantMembership[]
  destinationTransfers    Transfer[]              @relation("DestinationTransfers")
  originTransfers         Transfer[]              @relation("OriginTransfers")
  destinationRoutes       TransferRoute[]         @relation("DestinationRoutes")
  originRoutes            TransferRoute[]         @relation("OriginRoutes")
  userAttendances         UserAttendance[]
  userBranchAccesses      UserBranchAccess[]
  userRoleBranchHistories UserRoleBranchHistory[]

  @@map("branch")
}

model BranchConfig {
  id                String   @id @default(uuid())
  branchId          String
  openHours         Json
  daysInLaundry     Int
  daysInMaintenance Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  branch            Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@map("branch_configs")
}

model Brand {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  slug        String   @unique
  description String?
  logo        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  models      Model[]

  @@map("brand")
}

model CashSession {
  id                    String            @id @default(uuid())
  tenantId              String
  branchId              String
  openedById            String
  closedById            String?
  openedAt              DateTime
  closedAt              DateTime?
  sessionNumber         String
  status                CashSessionStatus
  openingAmount         Float             @default(0)
  closingExpectedAmount Float?
  closingCountedAmount  Float?
  closingDifference     Float?
  notes                 String?
  branch                Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  closedBy              User?             @relation("SessionCloser", fields: [closedById], references: [id], onDelete: Restrict)
  openedBy              User              @relation("SessionOpener", fields: [openedById], references: [id])
  tenant                Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payments              Payment[]

  @@map("cash_session")
}

model Category {
  id                String     @id @default(uuid())
  tenantId          String
  name              String
  description       String?
  parentId          String?
  level             Int        @default(0)
  path              String?
  image             String?
  color             String?
  icon              String?
  slug              String?    @unique
  order             Int        @default(0)
  isActive          Boolean    @default(true)
  showInPos         Boolean    @default(true)
  showInEcommerce   Boolean    @default(true)
  productCount      Int        @default(0)
  totalProductCount Int        @default(0)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  createdBy         String?
  updatedBy         String?
  parent            Category?  @relation("CategoryToCategory", fields: [parentId], references: [id], onDelete: Restrict)
  children          Category[] @relation("CategoryToCategory")
  tenant            Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products          Product[]

  @@map("category")
}

model Client {
  id                 String                @id @default(uuid())
  tenantId           String
  userName           String?
  firstName          String
  lastName           String
  dni                String                @unique
  email              String?
  phone              String
  address            String
  city               String
  province           String?
  zipCode            String?
  type               ClientType            @default(individual)
  walletBalance      Float                 @default(0)
  loyaltyPoints      Int                   @default(0)
  referralCode       String                @unique
  referredByClientId String?
  status             ClientStatus          @default(active)
  internalNotes      String?
  metadata           Json?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  createdBy          String?
  updatedBy          String?
  isDeleted          Boolean               @default(false)
  deletedAt          DateTime?
  deletedBy          String?
  deleteReason       String?
  referredBy         Client?               @relation("ClientReferrals", fields: [referredByClientId], references: [id])
  referredClients    Client[]              @relation("ClientReferrals")
  tenant             Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  creditLedger       ClientCreditLedger[]
  loyaltyLedger      ClientLoyaltyLedger[]
  coupons            Coupon[]
  operations         Operation[]
  referralReceived   Referral?             @relation("ReceivedReferral")
  referralsMade      Referral[]            @relation("MadeReferrals")
  reservations       Reservation[]

  @@map("client")
}

model ClientCreditLedger {
  id          String                      @id @default(uuid())
  tenantId    String
  clientId    String
  amount      Float                       @default(0)
  direction   ClientCreditLedgerDirection @default(credit)
  status      ClientCreditLedgerStatus    @default(confirmed)
  reason      ClientCreditLedgerReason    @default(manual_adjustment)
  operationId String?
  createdAt   DateTime                    @default(now())
  client      Client                      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  operation   Operation?                  @relation(fields: [operationId], references: [id], onDelete: Cascade)
  tenant      Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("client_credit_ledger")
}

model ClientLoyaltyLedger {
  id          String                       @id @default(uuid())
  tenantId    String
  clientId    String
  amount      Float                        @default(0)
  direction   ClientLoyaltyLedgerDirection @default(credit)
  status      ClientLoyaltyLedgerStatus    @default(confirmed)
  type        ClientLoyaltyLedgerType      @default(manual_adjustment)
  operationId String?
  description String?
  createdAt   DateTime                     @default(now())
  createdBy   String?
  expiresAt   DateTime?
  client      Client                       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  operation   Operation?                   @relation(fields: [operationId], references: [id], onDelete: Cascade)
  tenant      Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("client_loyalty_ledger")
}

model Coupon {
  id                 String       @id @default(uuid())
  tenantId           String
  code               String       @unique
  discountType       DiscountType
  discountValue      Float
  minPurchaseAmount  Float?
  assignedToClientId String
  origin             CouponOrigin
  originReferenceId  String?
  status             CouponStatus @default(available)
  expiresAt          DateTime?
  createdAt          DateTime     @default(now())
  usedAt             DateTime?
  assignedClient     Client       @relation(fields: [assignedToClientId], references: [id], onDelete: Cascade)
  tenant             Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("coupon")
}

model Guarantee {
  id                       String                   @id @default(uuid())
  tenantId                 String
  operationId              String
  branchId                 String
  type                     GuaranteeType
  value                    String
  description              String
  status                   GuaranteeStatus
  receivedById             String
  returnedById             String?
  createdAt                DateTime                 @default(now())
  returnedAt               DateTime?
  createdBy                String?
  updatedAt                DateTime                 @updatedAt
  updatedBy                String?
  guaranteeStatusHistories GuaranteeStatusHistory[]
  branch                   Branch                   @relation(fields: [branchId], references: [id])
  operation                Operation                @relation(fields: [operationId], references: [id], onDelete: Cascade)
  receivedBy               User                     @relation("GuaranteeReceiver", fields: [receivedById], references: [id])
  returnedBy               User?                    @relation("GuaranteeReturner", fields: [returnedById], references: [id], onDelete: Restrict)
  tenant                   Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("guarantee")
}

model GuaranteeStatusHistory {
  id          String          @id @default(uuid())
  tenantId    String
  guaranteeId String
  fromStatus  GuaranteeStatus
  toStatus    GuaranteeStatus
  reason      String?
  changedBy   String?
  createdAt   DateTime        @default(now())
  guarantee   Guarantee       @relation(fields: [guaranteeId], references: [id], onDelete: Cascade)
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Model {
  id          String    @id @default(uuid())
  tenantId    String
  brandId     String
  name        String
  slug        String    @unique
  description String?
  year        Int?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  brand       Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products    Product[]

  @@map("model")
}

model Module {
  id             String          @id @default(uuid())
  tenantId       String
  name           String
  slug           String          @unique
  description    String?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  tenantModules  TenantModule[]
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  moduleFeatures ModuleFeature[]

  @@map("module")
}

model ModuleFeature {
  id         String   @id @default(uuid())
  tenantId   String
  moduleId   String
  featureKey String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  module     Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("module_feature")
}

model Operation {
  id                   String                @id @default(uuid())
  tenantId             String
  referenceCode        String
  branchId             String
  sellerId             String
  type                 OperationType
  customerMode         CustomerMode          @default(registered)
  customerId           String?
  status               OperationStatus
  paymentStatus        PaymentStatus
  subtotal             Float?
  discountAmount       Float?
  totalAmount          Float
  date                 DateTime
  createdAt            DateTime              @default(now())
  configSnapshot       Json?
  configVersion        DateTime?
  policySnapshot       Json?
  policyVersion        Int?
  roundingAmount       Float?
  taxAmount            Float?
  taxRate              Float?
  totalBeforeRounding  Float?
  clientCreditLedgers  ClientCreditLedger[]
  clientLoyaltyLedgers ClientLoyaltyLedger[]
  guarantees           Guarantee[]
  branch               Branch                @relation(fields: [branchId], references: [id])
  customer             Client?               @relation(fields: [customerId], references: [id], onDelete: Restrict)
  seller               User                  @relation(fields: [sellerId], references: [id])
  tenant               Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payments             Payment[]
  rentals              Rental[]
  rentalCharges        RentalCharge[]
  rentalItems          RentalItem[]
  reservations         Reservation[]
  reservationItems     ReservationItem[]
  sales                Sale[]
  saleCharges          SaleCharge[]
  stockMovements       StockMovement[]
  discountsApplied     DiscountApplied[]

  @@unique([tenantId, referenceCode])
  @@map("operation")
}

model PaymentMethod {
  id           String            @id @default(uuid())
  name         String
  type         PaymentMethodType
  active       Boolean           @default(true)
  allowsChange Boolean           @default(false)
  requiresPin  Boolean           @default(false)
  icon         String?
  tenantId     String?
  payments     Payment[]
  tenant       Tenant?           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("payment_method")
}

model Payment {
  id                String           @id @default(uuid())
  tenantId          String
  operationId       String
  branchId          String
  receivedById      String
  amount            Float
  direction         PaymentDirection
  paymentMethodId   String
  cashSessionId     String?
  createdAt         DateTime         @default(now())
  currency          String           @default("PEN")
  status            PaymentStatusLog @default(pending)
  category          PaymentCategory
  originalPaymentId String?
  reference         String?
  date              DateTime
  notes             String?
  branch            Branch           @relation(fields: [branchId], references: [id])
  cashSession       CashSession?     @relation(fields: [cashSessionId], references: [id])
  operation         Operation        @relation(fields: [operationId], references: [id], onDelete: Cascade)
  paymentMethod     PaymentMethod    @relation(fields: [paymentMethodId], references: [id])
  receivedBy        User             @relation(fields: [receivedById], references: [id])
  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("payment")
}

model PayrollRun {
  id           String           @id @default(uuid())
  tenantId     String
  branchId     String
  periodStart  DateTime
  periodEnd    DateTime
  payDate      DateTime
  status       PayrollRunStatus
  createdAt    DateTime         @default(now())
  payrollItems PayrollItem[]
  branch       Branch           @relation(fields: [branchId], references: [id])
  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("payroll_run")
}

model PayrollItem {
  id             String               @id @default(uuid())
  tenantId       String
  payrollRunId   String
  membershipId   String
  grossTotal     Float
  deductionTotal Float
  netTotal       Float
  status         PayrollItemStatus
  membership     UserTenantMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  payrollRun     PayrollRun           @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  tenant         Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lineItems      PayrollLineItem[]

  @@map("payroll_item")
}

model PayrollLineItem {
  id            String              @id @default(uuid())
  tenantId      String
  payrollItemId String
  type          PayrollItemType
  category      PayrollItemCategory
  name          String
  amount        Float
  quantity      Int?
  rate          Float?
  createdAt     DateTime            @default(now())
  payrollItem   PayrollItem         @relation(fields: [payrollItemId], references: [id], onDelete: Cascade)
  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("payroll_line_item")
}

model PayrollPolicy {
  id                 String   @id @default(uuid())
  tenantId           String
  deductions         Json
  overtimeMultiplier Float
  createdAt          DateTime @default(now())
  createdBy          String
  updatedAt          DateTime @updatedAt
  updatedBy          String
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("payroll_policy")
}

model PayrollConfig {
  id                   String               @id @default(uuid())
  tenantId             String
  membershipId         String
  salaryType           String
  baseSalary           Float
  hourlyRate           Float
  paySchedule          PayScheduleType
  applyOvertime        Boolean
  applyHealthInsurance Boolean
  applyPension         Boolean
  applyTax             Boolean
  otherDeductions      Float
  createdAt            DateTime             @default(now())
  createdBy            String
  updatedAt            DateTime             @updatedAt
  updatedBy            String
  membership           UserTenantMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  tenant               Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("payroll_config")
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  module      String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  tenantId    String?
  tenant      Tenant?          @relation(fields: [tenantId], references: [id])
  roles       RolePermission[]

  @@map("permissions")
}

model Role {
  id                      String                  @id @default(cuid())
  tenantId                String
  name                    String                  @db.VarChar(50)
  description             String?
  isSystem                Boolean                 @default(false)
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  invitations             Invitation[]
  permissions             RolePermission[]
  tenant                  Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userTenantMemberships   UserTenantMembership[]
  userBranchAccesses      UserBranchAccess[]
  userRoleBranchHistories UserRoleBranchHistory[]

  @@unique([tenantId, name])
  @@map("roles")
}

model RolePermission {
  tenantId     String
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id])
  role         Role       @relation(fields: [roleId], references: [id])
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Plan {
  id                  String               @id @default(cuid())
  tenantId            String
  name                String               @db.VarChar(100)
  description         String?
  currency            String               @default("PEN")
  priceMonthly        Decimal              @db.Decimal(10, 2)
  priceYearly         Decimal?             @db.Decimal(10, 2)
  trialDays           Int?
  isActive            Boolean              @default(true)
  sortOrder           Int                  @default(0)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  features            PlanFeature[]
  limits              PlanLimit[]
  modules             PlanModule[]
  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantSubscriptions TenantSubscription[]

  @@map("plans")
}

model PlanFeature {
  id         String         @id @default(cuid())
  tenantId   String
  planId     String
  featureKey PlanFeatureKey
  plan       Plan           @relation(fields: [planId], references: [id])
  tenant     Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

